# Porta do servidor
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# String de conexão do MongoDB
# Local:   mongodb://localhost:27017/crud_de_listas
# Atlas:   mongodb+srv://<user>:<senha>@<cluster>.mongodb.net/crud_de_listas
MONGO_URI=mongodb://localhost:27017/crud_de_listas

# Segredo usado para assinar os tokens JWT (troque por um valor aleatório forte)
JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=1d
